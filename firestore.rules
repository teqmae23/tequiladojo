rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ロール判定 ─────────────────────────────────────────────
    // 1) Custom Claims（functions/setCustomClaims が members.role から同期）
    // 2) フォールバック: staffRoles/{uid} ドキュメント
    //    → どちらかで owner/staff なら許可（claims未反映でも締め出さない）
    function signedIn() { return request.auth != null; }
    function realUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function claimRole() {
      return signedIn() ? request.auth.token.get('role', '') : '';
    }
    function docRole() {
      return exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.get('role', '')
        : '';
    }
    function isOwner() {
      return signedIn() && (claimRole() == 'owner' || docRole() == 'owner');
    }
    function isStaff() {
      return signedIn()
        && (claimRole() in ['owner', 'staff'] || docRole() in ['owner', 'staff']);
    }

    // ── 会員情報（個人情報）: スタッフ全件 / 会員は自分のみ ─────
    // 作成・引継はCloud Functions（registerMember）がサーバー権限で行う
    match /members/{id} {
      allow read: if isStaff()
        || (realUser() && resource.data.get('authUid', '') == request.auth.uid);
      allow create: if isStaff();
      // 本人更新はプロフィール項目のみ。role等の保護フィールドは変更不可
      // （members.roleはsetCustomClaimsトリガーでAuth権限に同期されるため、
      //   本人がroleを書けると権限昇格できてしまう）
      allow update: if isStaff()
        || (realUser() && resource.data.get('authUid', '') == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                 ['role', 'authUid', 'realId', 'displayId', 'memberId',
                  'visitCount', 'totalAmount', 'totalTequila', 'rank',
                  'deleted', 'deletedAt', 'badgeCollectionUrl'].toSet()));
      allow delete: if isOwner();
    }

    // memberIndex: 会員ID→メール解決はFunctions（loginWithMemberId）が行うため
    // クライアントからはスタッフのみ（公開getはメール列挙につながるため廃止）
    match /memberIndex/{id} {
      allow read, write: if isStaff();
    }

    // memberPrivate: 会員のオーナー管理情報（目印写真URL・note・備考）。
    // 本人には読ませない。スタッフは閲覧のみ、編集（写真/note/備考）はオーナーのみ。
    match /memberPrivate/{id} {
      allow read: if isStaff();
      allow write: if isOwner();
    }

    // tempRegistrations: 引継コードの検証・消込はFunctions（registerMember）が行う
    match /tempRegistrations/{code} {
      allow read, write: if isStaff();
    }

    // ジャーナル（操作証跡）: スタッフのみ作成・閲覧、削除はオーナーのみ、改変不可
    match /journals/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if false;
      allow delete: if isOwner();
    }

    match /attendance/{id} { allow read, write: if isStaff(); }
    match /reservations/{id} { allow read, write: if isStaff(); }
    match /staffRoles/{uid} {
      allow read: if isStaff() || (signedIn() && request.auth.uid == uid);
      allow write: if isOwner();
    }

    // ── 日常業務（開店閉店・来場退場・注文・会計）: スタッフのみ ──
    // 会員向けページはCloud Functions（getMemberActivity / getStoreStatus）経由で
    // 本人分・公開情報のみ取得する
    match /visits/{id}        { allow read, write: if isStaff(); }
    match /orders/{id}        { allow read, write: if isStaff(); }
    match /cocktailOrders/{id}{ allow read, write: if isStaff(); }
    match /blindResults/{id}  { allow read, write: if isStaff(); }
    match /memberBadges/{id}  { allow read: if signedIn(); allow write: if isStaff(); }
    match /counters/{id}      { allow read, write: if isStaff(); }
    match /sessions/{id}      { allow read: if true;       allow write: if isStaff(); }
    match /storeStatus/{id}   { allow read: if true;       allow write: if isStaff(); }

    // ── 公開ポータル（index.html / news.html が未認証で読む） ──
    match /news/{id}           { allow read: if true; allow write: if isOwner(); }
    match /newsConfig/{id}     { allow read: if true; allow write: if isOwner(); }
    match /schedules/{id}      { allow read: if true; allow write: if isOwner(); }
    match /layouts/{id}        { allow read: if true; allow write: if isOwner(); }
    match /publicProfiles/{id} { allow read: if true; allow write: if isStaff(); }

    // ── 設定: memberCounter の採番はスタッフ（checkinのゲスト採番）と
    //    Functions（registerMember）のみ。realSeq巻き戻しは禁止 ──
    match /settings/memberCounter {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff()
        && request.resource.data.get('realSeq', 0) >= resource.data.get('realSeq', 0);
      allow delete: if isOwner();
    }
    match /settings/{id} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // 地図の市町村ドットキャッシュ: 閲覧クライアントがオンデマンド生成する
    match /dotMunicipios/{id} { allow read, write: if signedIn(); }

    // ── マスタデータ: 認証済みなら読み取り可（匿名含む）・書き込みはオーナー ──
    match /bottles/{id}        { allow read: if signedIn(); allow write: if isOwner(); }
    match /bottleData/{id}     { allow read: if signedIn(); allow write: if isOwner(); }
    match /brands/{id}         { allow read: if signedIn(); allow write: if isOwner(); }
    match /classes/{id}        { allow read: if signedIn(); allow write: if isOwner(); }
    match /distilleries/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /districts/{id}      { allow read: if signedIn(); allow write: if isOwner(); }
    match /locations/{id}      { allow read: if signedIn(); allow write: if isOwner(); }
    match /mapOverlays/{id}    { allow read: if signedIn(); allow write: if isOwner(); }
    match /cocktailMaster/{id} { allow read: if signedIn(); allow write: if isOwner(); }
    match /subMaterials/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /setProducts/{id}    { allow read: if signedIn(); allow write: if isOwner(); }
    match /miscProducts/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /otherBottles/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /blindMarks/{id}     { allow read: if signedIn(); allow write: if isOwner(); }
    match /badges/{id}         { allow read: if signedIn(); allow write: if isOwner(); }
    match /products/{id}       { allow read: if signedIn(); allow write: if isOwner(); }
    match /masterMeta/{id}     { allow read: if signedIn(); allow write: if isOwner(); }

    // ── その他（miscKinds, otherCat*, badgeTypes, calMeta, amm*, crt*,
    //    crtCountryMap, adminOps など管理ページ専用）: オーナーのみ ──
    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
